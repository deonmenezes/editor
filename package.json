{
  "name": "pascal-mcp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check-types": "turbo run check-types",
    "mcp": "node packages/mcp/dist/index.js",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
