{
  "name": "pascal-mcp",
  "version": "0.4.0",
  "description": "Build a shared 3D world through Claude. CRDT-synced; what you build appears live at https://editor-six-indol.vercel.app for everyone, instantly.",
  "author": {
    "name": "Deon Menezes",
    "url": "https://github.com/deonmenezes"
  },
  "homepage": "https://github.com/deonmenezes/editor",
  "repository": "https://github.com/deonmenezes/editor",
  "license": "MIT",
  "mcpServers": {
    "pascal": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"],
      "env": {
        "PASCAL_SCENE_PATH": "${CLAUDE_PLUGIN_DATA}/scene.json",
        "PASCAL_RELAY_URL": "wss://pascal-relay-deonmenezes.fly.dev",
        "PASCAL_ROOM": "pascal-shared-world"
      }
    }
  }
}
